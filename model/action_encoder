import torch 
from config import * 

class ActionChunkEncoder(nn.Module):
    def __init__(self): #make this linear -> gelu -> linear     
        super().__init__() 
        self.dof = dof
        self.dim = action_dim   

        self.action_proj = nn.Linear(dof, action_dim)
    
    def forward(self, action_chunk):
        #action_chunk shape: (B, length, dof) -> (B, length, action_dim)
        return self.action_proj(action_chunk)


class ProprioceptionEncoder(nn.Module):
    def __init__(self):
        super().__init__()
        self.dof = dof 
        self.dim = action_dim 
        
        self.proprio_proj = nn.Linear(dof, action_dim)


    def forward(self, proprio):
        # (B, dof) * (dof, dim) = (B, action_dim) -> unsqueeze(1) -> (B, 1, action_dim) 
        embed = self.proprio_proj(proprio) 
        return embed.unsqueeze(1)


